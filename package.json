{
  "name": "shunt-wizzard",
  "version": "1.0.0",
  "description": "Shunt Wizard Monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:dashboard": "npm run dev -w dashboard",
    "build": "npm run build -w backend && npm run build -w dashboard",
    "build:backend": "npm run build -w backend",
    "build:dashboard": "npm run build -w dashboard",
    "start:prod": "npm run start:prod -w backend",
    "seed": "npm run seed -w backend",
    "test": "npm run test -w backend",
    "lint": "npm run lint -w backend && npm run lint -w dashboard",
    "docker:up": "docker-compose up",
    "docker:up:build": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:seed": "docker-compose exec backend npm run seed"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
