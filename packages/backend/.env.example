NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=shunt_wizzard

# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRATION=15m

S3_STORAGE_BUCKET_NAME=your-bucket-name
S3_STORAGE_ACCESS_KEY=your-access-key
S3_STORAGE_SECRET_KEY=your-secret-key
S3_STORAGE_REGION=fr-par
S3_STORAGE_ENDPOINT=https://s3.fr-par.scw.cloud

# Comma-separated list of browser origins allowed to call the API.
# Mobile apps do not need to be listed here — CORS is browser-only.
# Example: https://dashboard.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:5173
