{
  "name": "shunt-merlin",
  "version": "1.0.0",
  "description": "ShuntMerlin Monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:backend": "turbo dev --filter=backend",
    "dev:dashboard": "turbo dev --filter=dashboard",
    "dev:mobile": "turbo dev --filter=mobile",
    "build": "turbo build",
    "build:backend": "turbo build --filter=backend",
    "build:dashboard": "turbo build --filter=dashboard",
    "start:prod": "pnpm run --filter=backend start:prod",
    "seed": "pnpm run --filter=backend seed",
    "test": "turbo test",
    "test:mobile": "turbo test --filter=mobile",
    "lint": "turbo lint",
    "docker:up": "docker-compose up",
    "docker:up:build": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:seed": "docker-compose exec backend pnpm run seed"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "@dr.pogodin/react-native-audio@1.18.0": "patches/@dr.pogodin__react-native-audio@1.18.0.patch"
    }
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
